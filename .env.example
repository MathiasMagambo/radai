# Core paths and listener
RADAI_ROOT=/opt/radai
RADIO_HOST=127.0.0.1
RADIO_PORT=8090
RADIO_WEB_DIR=web

# Web authentication
RADIO_USERNAME=radio
RADIO_PASSWORD=replace-with-a-long-random-password

# UI branding; point RADIO_WEB_DIR at another asset directory to replace the UI
SITE_NAME=RADAI
SITE_TITLE=Radai Radio
SITE_TAGLINE=PRIVATE INTERNET RADIO
SITE_MARK=R
SITE_FOOTER=RADIO.EXAMPLE.COM
SITE_LOGIN_INTRO=Sign in to manage the station and listen to the private stream.

# DeepSeek podcast planning
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Local Icecast source; the password must match Icecast's source-password
ICECAST_SOURCE_PASSWORD=
ICECAST_PORT=8001

# Spotify desktop and spotifyd
SPOTIFY_DEVICE_NAME=Radai Radio
SPOTIFY_CDP_URL=http://127.0.0.1:9223
SPOTIFYD_PATH=/home/radio/.local/bin/spotifyd

# Optional Telegram and legacy Spotify Web API commands
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Optional legacy service configuration
PUBLIC_BASE_URL=http://localhost:8000
ICECAST_URL=http://localhost:8000/radio.mp3
ICECAST_STATUS_URL=http://localhost:8000/status-json.xsl
LIQUIDSOAP_CONTROL_SOCKET=/tmp/radai-liquidsoap.sock
RADAI_DB_PATH=./data/radai.sqlite3
RADAI_MEDIA_DIR=./data/media
RADAI_RECORDINGS_DIR=./data/recordings
PODCAST_WINDOW_MINUTES=20
MUSIC_WINDOW_MINUTES=10
